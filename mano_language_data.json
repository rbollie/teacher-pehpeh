  "metadata": {
    "language_name": "Mano",
    "alternate_names": [
      "Mah",
      "Mahwe (Guinea dialect)"
    ],
    "iso_code": "mev",
    "language_family": "Mande (Southern Mande)",
    "region": "Nimba County, Liberia; Guinea",
    "writing_system": "Roman alphabet with IAA phonetic extensions",
    "orthography_established": 1928,
    "orthography_developer": "Dietrich Westermann / International Institute of African Languages (IAI)",
    "is_tonal": true,
    "source": "Gibbs, James L. (1988) Peoples of Africa, Cultures of Africa South of the Sahara. Waveland Press, pp. 583-584.",
    "structural_rules": [
      "All words end in vowels (no consonant-final words)",
      "No R, J, C, or Q in Liberian Mano",
      "蓴 is used for the R sound",
      "Z is used for the J sound",
      "No Mano word ends with the letter S",
      "kp and gb are always pronounced as single labiovelar sounds, never separately",
      "Tonal markers (accents/diacritics) over or under letters affect pronunciation and meaning",
      "Adjectives follow nouns (noun + adjective order, like French)",
      "No possessive pronouns - place pronoun before noun for possession",
      "No grammatical gender in pronouns - qualifying noun required for gender",
      "Base-5 counting system - numbers restart after 5",
      "No concept of zero",
      "Time is event-based, not calendar/date-based",
      "One word can mean many different things depending on tone and context (homonyms)",
      "Greetings are structured as questions"
    ],
    "dialect_regions": {
      "upper_nimba": "Upper Nimba",
      "middle_nimba": "Middle Nimba",
      "lower_nimba": "Lower Nimba",
      "guinea_mahwe": "Guinea Mahwe"
    }
  },
